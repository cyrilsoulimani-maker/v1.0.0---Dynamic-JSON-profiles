<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ======================================== -->
    <!-- DisplaySwitcher Design System -->
    <!-- Input Controls -->
    <!-- ======================================== -->

    <!-- DsTextBox -->

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource Ds.Panel}"/>
        <Setter Property="Foreground" Value="{StaticResource Ds.Text}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Ds.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="CaretBrush" Value="{StaticResource Ds.Accent}"/>
    </Style>

    <!-- DsComboBox -->

    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource Ds.Panel}"/>
        <Setter Property="Foreground" Value="{StaticResource Ds.Text}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Ds.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,4"/>
    </Style>

</ResourceDictionary>