<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="Ds.Background" Color="#111111"/>
    <SolidColorBrush x:Key="Ds.Panel" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="Ds.Accent" Color="#5FBF3A"/>
    <SolidColorBrush x:Key="Ds.Text" Color="#F2F2F2"/>
    <SolidColorBrush x:Key="Ds.TextSecondary" Color="#BDBDBD"/>
    <SolidColorBrush x:Key="Ds.Border" Color="#2A2A2A"/>
    <SolidColorBrush x:Key="Ds.AccentSubtle" Color="#203A18"/>
    <SolidColorBrush x:Key="Ds.AccentHover"
                 Color="#6ED645"/>
    <SolidColorBrush x:Key="Ds.Success"
                 Color="#4CAF50"/>

    <SolidColorBrush x:Key="Ds.PanelHover"
                 Color="#232323"/>
    <SolidColorBrush x:Key="Ds.BorderHover"
                 Color="#3A3A3A"/>

    <SolidColorBrush x:Key="Ds.BorderFocus"
                 Color="#5FBF3A"/>
    <CornerRadius x:Key="Ds.Corner.Small">6</CornerRadius>

    <CornerRadius x:Key="Ds.Corner.Medium">8</CornerRadius>

    <CornerRadius x:Key="Ds.Corner.Large">10</CornerRadius>

    <!-- ======================================== -->
    <!-- Design Tokens (migration vers Tokens.xaml) -->
    <!-- ======================================== -->

    <SolidColorBrush x:Key="Ds.PopupBackground"
                 Color="#202020"/>

    <SolidColorBrush x:Key="Ds.ItemHover"
                 Color="#2B2B2B"/>

    <SolidColorBrush x:Key="Ds.ItemSelected"
                 Color="#203C1A"/>

    <Thickness x:Key="Ds.BorderThickness">1</Thickness>

</ResourceDictionary>