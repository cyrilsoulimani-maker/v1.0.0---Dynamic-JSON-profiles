<Window x:Class="DisplaySwitcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DisplaySwitcher"
        Height="720"
        Width="1200"
        MinHeight="720"
        MinWidth="1200"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Ds.Background}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <DockPanel Margin="0,0,0,24">

            <Border Width="52"
                    Height="52"
                    CornerRadius="12"
                    Background="{StaticResource Ds.Accent}"
                    DockPanel.Dock="Left"
                    Margin="0,0,16,0">

                <TextBlock Text="DS"
                           Foreground="{StaticResource Ds.Background}"
                           FontSize="20"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="DisplaySwitcher"
                           FontSize="30"
                           FontWeight="Bold"/>

                <TextBlock Text="Tableau de bord"
                           Foreground="{StaticResource Ds.TextSecondary}"
                           FontSize="14"/>
            </StackPanel>

        </DockPanel>

        <!-- CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <!-- PROFILS -->
            <Border Grid.Column="0"
                    Style="{StaticResource Card}">

                <DockPanel>

                    <TextBlock DockPanel.Dock="Top"
                               Text="PROFIL À APPLIQUER"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,16"/>

                    <Button DockPanel.Dock="Bottom"
                            x:Name="ApplyButton"
                            Content="APPLIQUER"
                            Height="52"
                            FontSize="18"
                            Margin="0,20,0,0"
                            Click="ApplyButton_Click"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ProfilesItemsControl"
                                      ItemsSource="{Binding Profiles}">

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <RadioButton FontSize="18"
                                                 Margin="0,8"
                                                 GroupName="DisplayProfiles"
                                                 IsChecked="{Binding IsSelected, Mode=TwoWay}">

                                        <TextBlock>
                                            <Run Text="{Binding Name}"/>
                                            <Run Text=" — "/>
                                            <Run Text="{Binding Width}"/>
                                            <Run Text=" × "/>
                                            <Run Text="{Binding Height}"/>
                                            <Run Text=" @ "/>
                                            <Run Text="{Binding Frequency}"/>
                                            <Run Text=" Hz"/>
                                        </TextBlock>

                                    </RadioButton>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>

                        </ItemsControl>
                    </ScrollViewer>

                </DockPanel>

            </Border>

            <!-- RIGHT COLUMN -->
            <StackPanel Grid.Column="2">

                <!-- CURRENT STATE -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>

                        <TextBlock Text="ÉTAT ACTUEL"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12"/>

                        <TextBlock Text="Écran principal"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>

                        <TextBlock x:Name="CurrentResolutionText"
                                   FontSize="15"
                                   Foreground="{StaticResource Ds.TextSecondary}"
                                   Margin="0,8,0,0"/>

                    </StackPanel>
                </Border>

                <!-- TOOLS -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>

                        <TextBlock Text="OUTILS"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12"/>

                        <Button Content="Gérer les profils"
                                Height="42"
                                Click="ManageProfilesButton_Click"/>

                    </StackPanel>
                </Border>

            </StackPanel>

        </Grid>
    </Grid>
</Window>