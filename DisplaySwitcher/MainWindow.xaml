<Window x:Class="DisplaySwitcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DisplaySwitcher"
        Height="720"
        Width="1200"
        MinHeight="720"
        MinWidth="1200"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Ds.Background}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========================================================= -->
        <!-- HEADER -->
        <!-- ========================================================= -->

        <DockPanel Margin="0,0,0,24">
            <Border Width="52"
                    Height="52"
                    CornerRadius="12"
                    Background="{StaticResource Ds.Accent}"
                    DockPanel.Dock="Left"
                    Margin="0,0,16,0">

                <TextBlock Text="DS"
                           Foreground="{StaticResource Ds.Background}"
                           FontSize="20"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <TextBlock Text="v0.4"
                       DockPanel.Dock="Right"
                       Foreground="{StaticResource Ds.TextSecondary}"
                       VerticalAlignment="Center"
                       FontSize="14"/>

            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="DisplaySwitcher"
                           FontSize="30"
                           FontWeight="Bold"/>

                <TextBlock Text="Tableau de bord"
                           Foreground="{StaticResource Ds.TextSecondary}"
                           FontSize="14"/>
            </StackPanel>
        </DockPanel>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.25*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- ========================================================= -->
            <!-- CARTE : PROFIL À APPLIQUER -->
            <!-- ========================================================= -->

            <Border Grid.Column="0"
                    Margin="0"
        Style="{StaticResource DsCard}">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Margin="0,0,0,16">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
               Text="PROFIL À APPLIQUER"
               FontSize="16"
               FontWeight="SemiBold"/>

                        <Button Grid.Column="1"
            Style="{StaticResource DsHeaderButton}"
            Content="⚙"
            ToolTip="Gérer les profils"
            Click="ManageProfilesButton_Click"/>

                    </Grid>

                    <ScrollViewer
            Grid.Row="1"
            VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ProfilesItemsControl"
                                      ItemsSource="{Binding Profiles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <RadioButton FontSize="18"
                                                 Margin="0,6"
                                                 GroupName="DisplayProfiles"
                                                 IsChecked="{Binding IsSelected, Mode=TwoWay}">
                                        <TextBlock>
                                            <Run Text="{Binding Name}"/>
                                            <Run Text=" — "/>
                                            <Run Text="{Binding Width}"/>
                                            <Run Text=" × "/>
                                            <Run Text="{Binding Height}"/>
                                            <Run Text=" @ "/>
                                            <Run Text="{Binding Frequency}"/>
                                            <Run Text=" Hz"/>
                                        </TextBlock>
                                    </RadioButton>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ========================================================= -->
            <!-- CARTE : ÉTAT ACTUEL -->
            <!-- ========================================================= -->

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource DsCard}"
                        Margin="0">

                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
               Text="ÉTAT ACTUEL"
               FontSize="16"
               FontWeight="SemiBold"
               VerticalAlignment="Center"/>

                            <Button Grid.Column="1"
            Style="{StaticResource DsHeaderButton}"
            Content="↻"
            Click="RefreshButton_Click"/>
                        </Grid>

                        <TextBlock Text="🟢 Synchronisé avec Windows"
                                   FontSize="13"
                                   Foreground="{StaticResource Ds.Success}"
                                   Margin="0,0,0,20"/>

                        <TextBlock x:Name="CurrentProfileStatusText"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Ds.Accent}"/>

                        <TextBlock x:Name="CurrentProfileNameText"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Margin="0,2,0,24"/>

                        <TextBlock Text="Écran"
                                   FontSize="14"
                                   Foreground="{StaticResource Ds.TextSecondary}"/>

                        <TextBlock x:Name="CurrentDisplayNameText"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0,4,0,16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
               Grid.Column="0"
               Text="Résolution"
               FontSize="14"
               Foreground="{StaticResource Ds.TextSecondary}"/>

                            <TextBlock Grid.Row="0"
               Grid.Column="2"
               x:Name="CurrentResolutionText"
               FontSize="14"
               FontWeight="SemiBold"/>

                            <TextBlock Grid.Row="1"
               Grid.Column="0"
               Text="Fabricant"
               FontSize="14"
               Foreground="{StaticResource Ds.TextSecondary}"
               Margin="0,8,0,0"/>

                            <TextBlock Grid.Row="1"
               Grid.Column="2"
               Text="—"
               FontSize="14"
               Margin="0,8,0,0"/>

                            <TextBlock Grid.Row="2"
               Grid.Column="0"
               Text="Connexion"
               FontSize="14"
               Foreground="{StaticResource Ds.TextSecondary}"
               Margin="0,8,0,0"/>

                            <TextBlock Grid.Row="2"
               Grid.Column="2"
               Text="—"
               FontSize="14"
               Margin="0,8,0,0"/>

                            <TextBlock Grid.Row="3"
               Grid.Column="0"
               Text="HDR"
               FontSize="14"
               Foreground="{StaticResource Ds.TextSecondary}"
               Margin="0,8,0,0"/>

                            <TextBlock Grid.Row="3"
               Grid.Column="2"
               Text="—"
               FontSize="14"
               Margin="0,8,0,0"/>
                        </Grid>

                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ========================================================= -->
        <!-- ACTION PRINCIPALE -->
        <!-- ========================================================= -->

        <Button Grid.Row="2"
                x:Name="ApplyButton"
                Style="{StaticResource DsPrimaryButton}"
                Content="APPLIQUER"
                Height="56"
                FontSize="18"
                Margin="0,24,0,0"
                Click="ApplyButton_Click"/>
    </Grid>
</Window>