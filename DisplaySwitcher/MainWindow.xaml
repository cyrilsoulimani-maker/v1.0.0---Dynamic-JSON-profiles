<Window x:Class="DisplaySwitcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DisplaySwitcher"
        mc:Ignorable="d"
        Title="Display Switcher"
        Height="720"
        Width="1200"
        MinHeight="720"
        MinWidth="1200"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#181818">
    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="DISPLAY SWITCHER"
               FontSize="30"
               FontWeight="Bold"
               Foreground="White"
               HorizontalAlignment="Center"
               Margin="0,0,0,30"/>

        <Border Grid.Row="1"
            Background="#252525"
            CornerRadius="10"
            Padding="20">

            <StackPanel>

                <TextBlock Text="Écran principal"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="White"/>

                <TextBlock x:Name="CurrentResolutionText"
           FontSize="16"
           Foreground="#CCCCCC"
           Margin="0,10,0,0"/>

            </StackPanel>

        </Border>

        <StackPanel x:Name="ProfilesPanel"
            Grid.Row="2"
            Margin="0,30,0,30">
        </StackPanel>

        <Button Grid.Row="3"
        x:Name="ApplyButton"
        Content="APPLIQUER"
        Width="220"
        Height="60"
        FontSize="20"
        HorizontalAlignment="Center"
        Click="ApplyButton_Click"/>

    </Grid>
</Window>
