<Window x:Class="DisplaySwitcher.ProfileManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestion des profils"
        Height="500"
        Width="700"
        WindowStartupLocation="CenterOwner"
        Background="#181818">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <ListBox x:Name="ProfilesListBox"
         DisplayMemberPath="Name"
         FontSize="16"
         Margin="0,0,20,0"
         ItemsSource="{Binding Profiles}"
         SelectionChanged="ProfilesListBox_SelectionChanged"/>

        <StackPanel Grid.Column="1">

            <TextBlock Text="Nom" Foreground="White"/>
            <TextBox x:Name="NameTextBox"
         Margin="0,5,0,15"
         Text="{Binding SelectedItem.Name, ElementName=ProfilesListBox, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="Écran" Foreground="White" Margin="0,8,0,4" />
            <ComboBox
             ItemsSource="{Binding Displays}"
             DisplayMemberPath="DisplayName"
             SelectedValuePath="WindowsName"
             SelectedValue="{Binding SelectedItem.DisplayDeviceName, ElementName=ProfilesListBox, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
             SelectionChanged="DisplayComboBox_SelectionChanged"/>

            <TextBlock
             Text="Mode" Foreground="White"
             Margin="0,8,0,4"/>

            <ComboBox
             x:Name="ModeComboBox"
             ItemsSource="{Binding AvailableModes}"
             SelectionChanged="ModeComboBox_SelectionChanged" />

            <TextBlock Text="Largeur" Foreground="White"/>
            <TextBox x:Name="WidthTextBox"
         Margin="0,5,0,15"
         PreviewTextInput="NumericOnly_PreviewTextInput"            
         Text="{Binding SelectedItem.Width, ElementName=ProfilesListBox, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="Hauteur" Foreground="White"/>
            <TextBox x:Name="HeightTextBox"
         Margin="0,5,0,15"
         PreviewTextInput="NumericOnly_PreviewTextInput"
         Text="{Binding SelectedItem.Height, ElementName=ProfilesListBox, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="Fréquence" Foreground="White"/>
            <TextBox x:Name="FrequencyTextBox"
         Margin="0,5,0,25"
         PreviewTextInput="NumericOnly_PreviewTextInput"
         Text="{Binding SelectedItem.Frequency, ElementName=ProfilesListBox, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <CheckBox x:Name="CustomResolutionCheckBox"
          Content="Créer aussi cette résolution personnalisée dans Windows"
          Foreground="White"
          Margin="0,0,0,25"
          IsChecked="{Binding SelectedItem.CreateCustomResolution, ElementName=ProfilesListBox, Mode=TwoWay}"/>

            <StackPanel Orientation="Horizontal">
                <Button Content="💾 Enregistrer"
            Width="130"
            Margin="0,0,10,0"
            Click="SaveButton_Click"/>

                <Button Content="➕ Nouveau profil"
        Width="140"
        Margin="0,0,10,0"
        Click="NewProfileButton_Click"/>

                <Button Content="🗑 Supprimer"
        Width="120"
        Click="DeleteButton_Click"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</Window>